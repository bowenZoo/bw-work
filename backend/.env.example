# Application Configuration
DEBUG=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=18000

# LLM Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Langfuse Monitoring (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Image Generation Configuration
IMAGE_STORAGE_TYPE=local
IMAGE_STORAGE_PATH=data/projects
IMAGE_DEFAULT_PROVIDER=openai_default
IMAGE_GENERATION_TIMEOUT=120
IMAGE_ENABLE_PROMPT_ENHANCEMENT=false

# Additional Image Provider Keys (if using multiple providers)
# PROVIDER_A_TOKEN=your-provider-a-token
# PROVIDER_B_TOKEN=your-provider-b-token

# Project Discussion Configuration
PROJECT_DATA_DIR=data/projects
PROJECT_MAX_GDD_SIZE_MB=10
PROJECT_MAX_ROUNDS_PER_MODULE=10
PROJECT_CHECKPOINT_INTERVAL_SECONDS=60
PROJECT_CHECKPOINT_RETENTION_COUNT=5
PROJECT_CHECKPOINT_MAX_AGE_DAYS=30
PROJECT_WS_THROTTLE_MS=300
PROJECT_MODULE_DETECTION_MODEL=gpt-4
PROJECT_DESIGN_DOC_MODEL=gpt-4
